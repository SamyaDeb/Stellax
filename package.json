{
  "name": "stellax",
  "private": true,
  "version": "0.1.0",
  "description": "StellaX — Stellar's first unified derivatives exchange (perpetuals, options, structured products).",
  "license": "MIT OR Apache-2.0",
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "dev": "pnpm --filter @stellax/frontend dev",
    "evm:build": "cd contracts/evm && forge build",
    "evm:test": "cd contracts/evm && forge test",
    "testnet:preflight": "node scripts/testnet-preflight.mjs",
    "rwa:push-navs": "node scripts/push-rwa-navs.mjs",
    "oracle:keeper": "npm run oracle:keeper -w packages/e2e"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
