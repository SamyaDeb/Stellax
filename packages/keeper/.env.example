# StellaX Keeper — environment configuration
# Copy this file to .env and fill in values for your environment.

# ─── Stellar network ──────────────────────────────────────────────────────────
# Horizon / Soroban RPC URL
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
# Network passphrase: "Test SDF Network ; September 2015" for testnet, "Public Global Stellar Network ; September 2015" for mainnet.
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# ─── Keeper identity ──────────────────────────────────────────────────────────
# Secret key (S...) of the keeper account. MUST be funded with XLM for fees.
KEEPER_SECRET_KEY=

# ─── Contract addresses (populate after deployment) ───────────────────────────
ORACLE_CONTRACT_ID=
FUNDING_CONTRACT_ID=
PERP_ENGINE_CONTRACT_ID=
RISK_CONTRACT_ID=
OPTIONS_CONTRACT_ID=
STRUCTURED_CONTRACT_ID=

# ─── RedStone ─────────────────────────────────────────────────────────────────
# HTTP gateway(s) to fetch signed price payloads from.
REDSTONE_GATEWAY_URL=https://oracle-gateway-1.a.redstone.finance
# Comma-separated feed symbols (e.g., BTC,ETH,XLM,SOL,LINK,EUR,XAU)
REDSTONE_FEEDS=BTC,ETH,XLM,SOL,LINK,EUR,XAU
# Data-service identifier on RedStone
REDSTONE_DATA_SERVICE_ID=redstone-primary-prod
# How many signer attestations to request
REDSTONE_UNIQUE_SIGNERS=3

# ─── Worker intervals (milliseconds) ──────────────────────────────────────────
ORACLE_PUSH_INTERVAL_MS=10000
FUNDING_UPDATE_INTERVAL_MS=3600000
LIQUIDATION_SCAN_INTERVAL_MS=5000
OPTION_SETTLE_INTERVAL_MS=3600000
VAULT_ROLL_INTERVAL_MS=60000

# ─── Worker enable flags ──────────────────────────────────────────────────────
WORKER_ORACLE_ENABLED=true
WORKER_FUNDING_ENABLED=true
WORKER_LIQUIDATION_ENABLED=true
WORKER_OPTIONS_ENABLED=true
WORKER_VAULT_ENABLED=true

# ─── Market / vault IDs the keeper services ──────────────────────────────────
# Comma-separated u32 market IDs for funding / liquidation scanning
PERP_MARKET_IDS=1,2,3
# Comma-separated vault contract IDs to roll (may be same as STRUCTURED_CONTRACT_ID if single vault)
STRUCTURED_VAULT_IDS=

# ─── Monitoring & alerting ────────────────────────────────────────────────────
HEALTH_PORT=9090
LOG_LEVEL=info
# Optional webhooks for critical alerts
ALERT_DISCORD_WEBHOOK=
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=

# ─── Thresholds ───────────────────────────────────────────────────────────────
# Alert if keeper wallet XLM balance drops below this (stroops; 1 XLM = 10^7)
MIN_KEEPER_BALANCE_STROOPS=1000000000
# Alert if oracle stale > this (ms)
ORACLE_STALENESS_ALERT_MS=60000
