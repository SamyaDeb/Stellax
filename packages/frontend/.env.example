# Dev / test settings. Values here are loaded by Vite via `import.meta.env`.
# Any variable prefixed with VITE_ is exposed to the client bundle.

VITE_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
VITE_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

